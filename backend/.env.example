# Server-Konfiguration
PORT=3001
NODE_ENV=development

# JWT Secret (unbedingt ändern für Produktion!)
JWT_SECRET=CHANGE_ME_random_secret_min_32_chars
JWT_EXPIRES_IN=7d

# Admin-Zugangsdaten
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_sicheres_passwort
ADMIN_EMAIL=admin@example.com

# E-Mail-Konfiguration (Gmail SMTP)
# Für Gmail: App-Passwort unter https://myaccount.google.com/apppasswords erstellen
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=deine-email@gmail.com
SMTP_PASS=dein_app_passwort
SMTP_FROM=deine-email@gmail.com

# Frontend URL (für E-Mail-Links)
FRONTEND_URL=http://localhost:5173

# Upload-Verzeichnis
UPLOAD_DIR=./uploads
